FROM golang:1.17-bullseye

ARG APP_PATH TERRAFORM_PATH

RUN apt-get install -y unzip

RUN curl https://releases.hashicorp.com/terraform/1.3.0/terraform_1.3.0_linux_amd64.zip --output terraform.zip
RUN unzip terraform.zip
RUN mkdir -p $APP_PATH/$TERRAFORM_PATH
COPY terraform $APP_PATH/$TERRAFORM_PATH/terraform

RUN go install github.com/hashicorp/terraform-plugin-docs/cmd/tfplugindocs@v0.7.0

RUN mkdir -p $APP_PATH
COPY . $APP_PATH
WORKDIR $APP_PATH
